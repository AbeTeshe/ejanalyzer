

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}



model Transaction {
  id          Int      @id @default(autoincrement())
  customerTin String
  mrc         String
  fsNo        String
  buyerTin    String?
  date        DateTime
  grandTotal  Float
  lineItems   LineItem[]
  @@unique([mrc, fsNo]) 
  @@map("transactions") // optional: maps to a SQL table named "transactions"
}


model LineItem {
  id           Int     @id @default(autoincrement())
  transaction  Transaction @relation(fields: [transactionId], references: [id])
  transactionId Int
  item         String
  unitAmount   Float
  quantity     Int
  totalAmount  Float
  vatAmount    Float

  @@map("lineitems")
}





