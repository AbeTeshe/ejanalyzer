generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model lineitems {
  id            Int          @id @default(autoincrement())
  transactionId Int
  item          String
  unitAmount    Float
  quantity      Int
  totalAmount   Float
  vatAmount     Float
  transactions  transactions @relation(fields: [transactionId], references: [id])

  @@index([transactionId], map: "lineitems_transactionId_fkey")
}

model transactions {
  id          Int         @id @default(autoincrement())
  customerTin String
  mrc         String
  fsNo        String
  buyerTin    String?
  date        DateTime
  grandTotal  Float
  lineitems   lineitems[]

  @@unique([mrc, fsNo])
}
